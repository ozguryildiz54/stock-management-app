# "firmId": "65343222b67e9681f937f305",
# "price": 900

{
    "quantity": 
}

###

# @name sales
put {{baseUrl}}/sales/68d442c18f2707c5b0b7fe28
Content-Type: application/json
Authorization: {{accessToken}}

